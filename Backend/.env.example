# Required security settings
SECRET_KEY=replace-with-a-random-64-char-secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-password-at-least-12-chars
ADMIN_DISPLAY_NAME=Admin Analyst

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/soc_alerts

# Frontend origins (comma-separated exact origins)
FRONTEND_ORIGINS=http://localhost:5173,http://localhost:3000

# Session cookie hardening
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=lax
SESSION_COOKIE_MAX_AGE_SECONDS=28800

# Login protection
LOGIN_MAX_ATTEMPTS=5
LOGIN_WINDOW_SECONDS=300
LOGIN_LOCKOUT_SECONDS=900

# Wazuh
WAZUH_API_URL=https://wazuh-manager:55000
WAZUH_USERNAME=replace-me
WAZUH_PASSWORD=replace-me
WAZUH_VERIFY_SSL=true
WAZUH_INDEXER_URL=https://wazuh-indexer:9200
WAZUH_INDEXER_USERNAME=replace-me
WAZUH_INDEXER_PASSWORD=replace-me
WAZUH_INDEX_PATTERN=wazuh-alerts-*

# Remote ML
ML_CLASSIFICATION_PROVIDER=remote
ML_REMOTE_URL=
ML_REMOTE_API_KEY=
ML_REMOTE_API_KEY_HEADER=X-API-Key
ML_REMOTE_TIMEOUT_SECONDS=8
ML_CLASSIFICATION_FALLBACK_LOCAL=false
ML_CLASSIFICATION_MAX_RETRIES=5
ML_CLASSIFICATION_RETRY_DELAY_MINUTES=10

# Optional LLM enrichment
GEMINI_API_KEY=
